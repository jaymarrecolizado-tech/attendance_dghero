# ISSP Solo - Environment Configuration
# Copy this file to .env and update with your actual values

# Database Configuration
DB_HOST=localhost
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASS=your_database_password

# Database Auto-Migration (set to false in production after initial setup)
DB_AUTO_MIGRATE=false

# SMTP Email Configuration
MAIL_MODE=smtp
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=your_email@digitalbayanihan.site
SMTP_PASS=your_email_password
SMTP_SECURE=ssl
SMTP_FROM=your_email@digitalbayanihan.site

# Content Security Policy (set to true for stricter security)
CSP_STRICT=false

# Application URL (for email links, etc.)
APP_URL=https://digitalbayanihan.site

# Timezone
TZ=Asia/Manila

